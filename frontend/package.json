{
  "name": "radiology-ai-frontend",
  "private": true,
  "version": "1.0.0",
  "main": "../electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.12"
  }
  ,
  "build": {
    "appId": "com.kidneyscan.ai",
    "productName": "KidneyScan AI",
    "icon": "../electron/icon.png",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "dist/**/*",
      "../electron/**/*",
      "../backend/**/*",
      "!../backend/myenv/**/*",
      "!../backend/dataset/**/*",
      "!../backend/static/uploads/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "../electron/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron ../electron/main.js",
    "dist": "vite build && electron-builder"
  }
}
